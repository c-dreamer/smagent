# Copy to .env only on the machine that runs smagent. Never commit .env.

# Required for evidence-first Faith Nexus script generation.
NVIDIA_API_KEY=
NVIDIA_TEXT_MODEL=
NVIDIA_NIM_URL=https://integrate.api.nvidia.com/v1/chat/completions

# Optional local or remote ComfyUI worker. Leave unset when using licensed stock.
COMFYUI_URL=http://127.0.0.1:8188

# Optional stock-search providers; maintain source licence data in every manifest.
# On this workstation smagent also recognises ../human-ai.env2; deployments use
# regular environment variables instead.
PEXELS_API_KEY=
PIXABAY_API_KEY=
